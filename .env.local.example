# ============================================
# SJT 챗봇 - API 키 설정
# ============================================

# ── LLM API (최소 1개 필수) ──
# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── LangSmith (선택, 비용 추적용) ──
# https://smith.langchain.com/ 에서 가입 후 Settings > API Keys 에서 발급
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sjt-chatbot

# ── Google Drive (선택, 세션 로그 클라우드 저장) ──
# Service Account 방식 (토큰 만료 없음)
# 설정 방법은 README 참고
#
# 방법 A: Service Account JSON 전체를 한 줄로 넣기
GOOGLE_SERVICE_ACCOUNT_KEY=
#
# 방법 B: 개별 필드로 넣기 (Vercel 등에서 편리)
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
#
# 저장할 Google Drive 폴더 ID
GOOGLE_DRIVE_FOLDER_ID=
